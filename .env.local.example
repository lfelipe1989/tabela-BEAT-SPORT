# Copie este arquivo para ".env.local" (localmente) e configure
# as mesmas chaves em Vercel > Project Settings > Environment Variables.

# Encontrado em Supabase > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Encontrado em Supabase > Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Encontrado em Supabase > Project Settings > API > Project API keys > service_role
# NUNCA exponha esta chave no navegador — ela só é usada dentro das API routes (servidor).
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Senha simples para liberar ações de edição (cadastrar atleta, criar etapa,
# lançar resultados). Escolha uma senha só sua.
ADMIN_PASSWORD=escolha_uma_senha_forte
